{
  "name": "markdown-exit-mermaid",
  "version": "2.2.2",
  "description": "A markdown-exit plugin for rendering Mermaid diagrams in a secure iframe with viewer controls",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/Efterklang/markdown-exit-mermaid"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "bun ./test/test.ts",
    "build": "vite build"
  },
  "keywords": [
    "markdown-exit",
    "mermaid",
    "diagram",
    "plugin",
    "markdown"
  ],
  "author": "GnixAij",
  "license": "MIT",
  "peerDependencies": {
    "markdown-exit": "^1.0.0-beta.9"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^4.0.0"
  }
}
